@page
@model MyRazorApp.Pages.IndexModel
 
<h2>Student Registration Portal</h2>

<form method="post">
    <div>
        <label>Enter Student Name:</label>
        <input asp-for="Name" />
    </div>

    <br />

    <button type="submit">Register</button>
</form>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <h3>@Model.Message</h3>
}