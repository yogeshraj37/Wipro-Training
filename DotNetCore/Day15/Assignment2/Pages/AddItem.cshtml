@page
@model AddItemModel
@{
    ViewData["Title"] = "Add Item";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h3 mb-3">Add a New Item</h1>
                <p class="text-muted">Create a new item and it will appear on the list page automatically.</p>

                <form method="post">
                    <div class="mb-3">
                        <label asp-for="NewItem" class="form-label">Item name</label>
                        <input asp-for="NewItem" class="form-control" placeholder="Enter item name" />
                        <span asp-validation-for="NewItem" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Add Item</button>
                        <a asp-page="/Index" class="btn btn-secondary">Back to list</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
