@* Orders/Confirmation.cshtml *@
@model BookstoreApp.Models.Order
@{
    ViewData["Title"] = "Order Confirmed";
}

<div style="text-align:center; padding:2rem 0 1rem">
    <div style="font-size:4rem">✅</div>
    <h1 style="font-family:'Playfair Display',serif; color:var(--green); margin:0.5rem 0">Order Confirmed!</h1>
    <p style="color:#666">Order #@Model.Id · Placed on @Model.PlacedAt.ToString("dd MMM yyyy, hh:mm tt")</p>
</div>

<div style="max-width:600px; margin:0 auto">
    <div style="background:white; border-radius:12px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.08); margin-bottom:1.5rem">
        <h3 style="font-family:'Playfair Display',serif; margin-bottom:1rem; color:var(--brown)">Order Summary</h3>
        @foreach (var item in Model.Items)
        {
            <div style="display:flex; justify-content:space-between; padding:0.5rem 0; border-bottom:1px solid var(--light)">
                <span>@item.Title <span style="color:#888">× @item.Quantity</span></span>
                <span style="font-weight:600">₹@item.Subtotal.ToString("N2")</span>
            </div>
        }
        <div style="display:flex; justify-content:space-between; font-weight:700; padding-top:0.8rem; font-size:1.1rem; color:var(--brown)">
            <span>Total Paid</span>
            <span>₹@Model.TotalAmount.ToString("N2")</span>
        </div>
    </div>

    <div style="background:var(--light); border-radius:10px; padding:1.2rem; margin-bottom:1.5rem">
        <p style="font-weight:600; margin-bottom:0.3rem">📦 Shipping to:</p>
        <p style="color:#555; line-height:1.6">@Model.ShippingAddress</p>
    </div>

    <div style="display:flex; gap:1rem; justify-content:center">
        <a href="/orders" class="btn btn-primary">My Orders</a>
        <a href="/catalog" class="btn btn-gold">Continue Shopping</a>
    </div>
</div>
