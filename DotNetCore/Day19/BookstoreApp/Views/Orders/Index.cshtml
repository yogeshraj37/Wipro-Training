@* Orders/Index.cshtml — User's own order history *@
@model IEnumerable<BookstoreApp.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<h1 style="font-family:'Playfair Display',serif; color:var(--brown); margin-bottom:1.5rem">📦 My Orders</h1>

@if (!Model.Any())
{
    <div style="text-align:center; padding:3rem; background:white; border-radius:12px">
        <p style="color:#888; margin-bottom:1rem">You haven't placed any orders yet.</p>
        <a href="/catalog" class="btn btn-gold">Start Shopping</a>
    </div>
}
else
{
    @foreach (var order in Model)
    {
        <div style="background:white; border-radius:10px; padding:1.5rem; box-shadow:0 2px 8px rgba(0,0,0,0.07); margin-bottom:1.2rem">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem; flex-wrap:wrap; gap:0.5rem">
                <div>
                    <span style="font-weight:700; font-size:1.05rem">Order #@order.Id</span>
                    <span style="color:#888; font-size:0.85rem; margin-left:0.8rem">@order.PlacedAt.ToString("dd MMM yyyy")</span>
                </div>
                <span style="background:@(order.Status == "Confirmed" ? "#d4edda" : order.Status == "Delivered" ? "#cce5ff" : "#fff3cd"); 
                             color:@(order.Status == "Confirmed" ? "#155724" : order.Status == "Delivered" ? "#004085" : "#856404");
                             padding:0.25rem 0.8rem; border-radius:12px; font-size:0.8rem; font-weight:600">
                    @order.Status
                </span>
            </div>
            <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:0.8rem">
                @foreach (var item in order.Items)
                {
                    <span style="background:var(--light); padding:0.3rem 0.7rem; border-radius:20px; font-size:0.85rem">@item.Title × @item.Quantity</span>
                }
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center">
                <span style="font-weight:700; color:var(--brown)">₹@order.TotalAmount.ToString("N2")</span>
                <a href="/orders/confirmation/@order.Id" class="btn btn-sm btn-primary">View Details</a>
            </div>
        </div>
    }
}
