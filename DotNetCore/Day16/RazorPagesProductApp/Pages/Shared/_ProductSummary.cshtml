@model RazorPagesProductApp.Models.Product

<div style="border:1px solid gray;padding:10px;margin:10px">

    <h3>@Model.Name</h3>

    <p>@Model.Description</p>

    <b>Categories:</b>

    <ul>
        @foreach (var category in Model.Categories)
        {
            <li>@category.Name</li>
        }
    </ul>

</div>