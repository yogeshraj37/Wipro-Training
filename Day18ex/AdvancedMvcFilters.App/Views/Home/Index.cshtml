@{
    ViewData["Title"] = "Advanced MVC Filters";
}

<div class="p-4 bg-light rounded border">
    <h1 class="display-5">Advanced MVC Filters Assignment</h1>
    <p class="lead">E-commerce and online banking examples using dependency-injected MVC filters.</p>
    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-primary" asp-controller="Products" asp-action="Index">Products</a>
        <a class="btn btn-outline-primary" asp-controller="Orders" asp-action="Index">Orders</a>
        <a class="btn btn-outline-success" asp-controller="Banking" asp-action="Accounts">Bank Accounts</a>
        <a class="btn btn-outline-secondary" asp-controller="Banking" asp-action="AdminAccounts">Admin Accounts</a>
    </div>
</div>
