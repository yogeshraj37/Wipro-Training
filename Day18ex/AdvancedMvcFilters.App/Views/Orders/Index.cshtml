@model IEnumerable<AdvancedMvcFilters.App.Models.Order>
@{
    ViewData["Title"] = "Orders";
}

<h1>Orders</h1>
<table class="table table-striped">
    <thead>
        <tr><th>Order</th><th>Product</th><th>Amount</th><th>Status</th></tr>
    </thead>
    <tbody>
    @foreach (var order in Model)
    {
        <tr><td>@order.Id</td><td>@order.ProductName</td><td>@order.Amount.ToString("C")</td><td>@order.Status</td></tr>
    }
    </tbody>
</table>
<a class="btn btn-outline-danger" asp-action="SimulateError">Test error filter</a>
