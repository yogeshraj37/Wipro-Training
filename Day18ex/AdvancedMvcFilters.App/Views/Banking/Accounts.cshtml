@model IEnumerable<AdvancedMvcFilters.App.Models.BankAccount>
@{
    ViewData["Title"] = "Accounts";
}

<h1>Accounts</h1>
<table class="table table-striped">
    <thead>
        <tr><th>Number</th><th>Type</th><th>Balance</th></tr>
    </thead>
    <tbody>
    @foreach (var account in Model)
    {
        <tr><td>@account.Number</td><td>@account.Type</td><td>@account.Balance.ToString("C")</td></tr>
    }
    </tbody>
</table>
