@model IEnumerable<AdvancedMvcFilters.App.Models.BankTransaction>
@{
    ViewData["Title"] = "Transactions";
}

<h1>Transactions</h1>
<table class="table table-striped">
    <thead>
        <tr><th>ID</th><th>Description</th><th>Amount</th><th>Date</th></tr>
    </thead>
    <tbody>
    @foreach (var transaction in Model)
    {
        <tr><td>@transaction.Id</td><td>@transaction.Description</td><td>@transaction.Amount.ToString("C")</td><td>@transaction.Date.ToShortDateString()</td></tr>
    }
    </tbody>
</table>
