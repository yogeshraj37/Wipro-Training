@{
    ViewData["Title"] = "Transfer";
}

<h1>Transfer</h1>
<form class="col-md-5">
    <div class="mb-3">
        <label class="form-label" for="toAccount">To account</label>
        <input class="form-control" id="toAccount" value="SB-2002" />
    </div>
    <div class="mb-3">
        <label class="form-label" for="amount">Amount</label>
        <input class="form-control" id="amount" value="1000" />
    </div>
    <button class="btn btn-primary" type="button">Submit transfer</button>
</form>
